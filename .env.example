# =========================
# PostgreSQL 数据库配置
# =========================
POSTGRES_DB=ai_diary          # 数据库名称
POSTGRES_USER=ai_diary        # 数据库用户名
POSTGRES_PASSWORD=ai_diary    # 数据库密码
POSTGRES_PORT=5432            # 数据库端口（默认5432）

# =========================
# Redis 缓存配置
# =========================
REDIS_PORT=6379               # Redis 端口（默认6379）

# =========================
# MinIO 对象存储配置（类似 S3）
# =========================
MINIO_ROOT_USER=minioadmin        # 管理员账号
MINIO_ROOT_PASSWORD=minioadmin123 # 管理员密码
MINIO_API_PORT=9000               # API访问端口（程序用）
MINIO_CONSOLE_PORT=9001           # 控制台端口（浏览器访问）
MINIO_BUCKET=ai-diary             # 存储桶名称（类似文件夹）

# =========================
# 前端（Next.js）访问后端配置
# =========================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1   # HTTP接口地址
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/api/v1      # WebSocket地址（实时通信）

# =========================
# Python 后端服务配置
# =========================
PYTHON_API_PORT=8000           # Python API 运行端口
PYTHON_API_ENV=development     # 运行环境（development/production）
PYTHON_API_SECRET_KEY=replace-me # 密钥（用于JWT/加密，生产环境必须修改）

# =========================
# Go 网关服务配置
# =========================
GO_GATEWAY_PORT=8080           # Go 网关端口（统一入口）