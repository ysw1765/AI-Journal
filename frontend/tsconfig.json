{
  "compilerOptions": {
    // =========================
    // 编译目标 & 运行环境
    // =========================
    "target": "ES2020", // 编译后的 JavaScript 版本（支持现代语法）
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ], // 使用哪些内置API（浏览器 + ES2020）
    // =========================
    // 基础行为
    // =========================
    "allowJs": false, // 是否允许编译 JS 文件（false = 只用 TS）
    "skipLibCheck": true, // 跳过第三方库类型检查（提高速度）
    "strict": true, // 开启严格模式（强烈推荐）
    // =========================
    // 输出控制
    // =========================
    "noEmit": true, // 不生成 JS 文件（交给 Next.js/Vite 打包）
    // =========================
    // 模块系统
    // =========================
    "esModuleInterop": true, // 兼容 CommonJS 模块（import 更方便）
    "module": "esnext", // 使用最新的 ES 模块规范
    "moduleResolution": "bundler", // 用打包工具方式解析模块（适合 Next.js）
    // =========================
    // 功能支持
    // =========================
    "resolveJsonModule": true, // 允许 import JSON 文件
    "isolatedModules": true, // 每个文件独立编译（适配构建工具）
    "jsx": "preserve", // 保留 JSX，不转换（交给框架处理）
    // =========================
    // 性能优化
    // =========================
    "incremental": true, // 启用增量编译（加快编译速度）
    // =========================
    // 路径别名（非常常用）
    // =========================
    "baseUrl": ".", // 基础路径（当前目录）
    "paths": {
      "@/*": [
        "./src/*"
      ] // @ 指向 src 目录（简化导入路径）
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  // =========================
  // 包含哪些文件
  // =========================
  "include": [
    "**/*.ts", // Next.js 自动生成的类型文件
    "**/*.tsx", // 所有 ts 文件
    "next-env.d.ts" // 所有 tsx 文件
    ,
    ".next/types/**/*.ts"
  ],
  // =========================
  // 排除哪些文件
  // =========================
  "exclude": [
    "node_modules" // 排除依赖目录
  ]
}
